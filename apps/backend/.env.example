# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/debateai

# Redis
REDIS_URL=redis://localhost:6379

# JWT Settings
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Fact Checking APIs
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=your-serper-api-key

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,https://debateai.vercel.app

# App Settings
DEBUG=True
LOG_LEVEL=INFO
